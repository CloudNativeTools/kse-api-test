{
  "global_rule_group_template_node_single": {
    "apiVersion": "alerting.kubesphere.io/v2beta1",
    "kind": "GlobalRuleGroup",
    "metadata": {
      "name": "PLACEHOLDER",
      "labels": {
        "alerting.kubesphere.io/enable": "true"
      },
      "annotations": {
        "kubesphere.io/creator": "admin"
      }
    },
    "annotations": {
      "aliasName": "",
      "description": ""
    },
    "spec": {
      "interval": "10s",
      "partial_response_strategy": "",
      "rules": [
        {
          "alert": "PLACEHOLDER",
          "annotations": {
            "summary": "global memory over 10%",
            "message": ""
          },
          "exprBuilder": {
            "node": {
              "names": [
                {
                  "cluster": "host",
                  "names": ["node3", "node2", "node1"]
                }
              ],
              "metricThreshold": {
                "memory": {
                  "utilization": 0.1
                }
              },
              "comparator": ">"
            }
          },
          "disable": false,
          "for": "1m",
          "severity": "critical"
        }
      ]
    }
  },
