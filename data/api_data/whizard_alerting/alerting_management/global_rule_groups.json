  "global_rule_group_template_workload_single": {
    "apiVersion": "alerting.kubesphere.io/v2beta1",
    "kind": "GlobalRuleGroup",
    "metadata": {
      "name": "PLACEHOLDER",
      "labels": {
        "alerting.kubesphere.io/enable": "true"
      },
      "annotations": {
        "kubesphere.io/creator": "admin"
      }
    },
    "annotations": {
      "aliasName": "",
      "description": ""
    },
    "spec": {
      "interval": "",
      "partial_response_strategy": "",
      "rules": [
        {
          "alert": "PLACEHOLDER",
          "annotations": {
            "summary": "workload memory over 5MiB",
            "message": ""
          },
          "namespaceSelector": {
            "inValues": ["host-pro1-test"]
          },
          "expr": "",
          "exprBuilder": {
            "workload": {
              "names": [
                {
                  "cluster": "host",
                  "namespace": "host-pro1-test",
                  "names": ["host-nginx"]
                }
              ],
              "metricThreshold": {
                "memory": {
                  "usage": 5242880
                }
              },
              "kind": "Deployment",
              "comparator": ">"
            }
          },
          "disable": false,
          "for": "1m",
          "severity": "error"
        }
      ]
    }
  },
