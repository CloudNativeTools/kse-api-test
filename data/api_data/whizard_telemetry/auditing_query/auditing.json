{
  "time_ranges": {
    "last_1h": {
      "start_time": "{{timestamp_last_1h}}",
      "end_time": "{{timestamp}}"
    },
    "last_3h": {
      "start_time": "{{timestamp_last_3h}}",
      "end_time": "{{timestamp}}"
    },
    "last_6h": {
      "start_time": "{{timestamp_last_6h}}",
      "end_time": "{{timestamp}}"
    }
  },
  "filters": {
    "verb_create": {
      "verb_filter": "create"
    },
    "verb_post": {
      "verb_filter": "POST"
    },
    "namespace_host": {
      "objectref_namespace_filter": "{{projects.host.name}}"
    },
    "resource_deployment": {
      "objectref_resource_filter": "deployments"
    },
    "response_code_200": {
      "response_code_filter": "200"
    },
    "user_search": {
      "user_search": "admin"
    },
    "objectref_name_search": {
      "objectref_name_search": "nginx"
    },
    "source_ip_search": {
      "source_ip_search": "10."
    }
  },
  "pagination": {
    "page_1": {
      "from": 0,
      "size": 5
    },
    "page_2": {
      "from": 5,
      "size": 5
    }
  },
  "histogram": {
    "interval_30m": {
      "interval": "30m"
    },
    "interval_1h": {
      "interval": "1h"
    }
  },
  "invalid_params": {
    "missing_time_range": {},
    "invalid_interval": {
      "operation": "histogram",
      "interval": "invalid"
    },
    "negative_from": {
      "operation": "query",
      "from": -1
    },
    "zero_size": {
      "operation": "query",
      "size": 0
    }
  }
}