{
  "time_ranges": {
    "last_1h": {
      "start_time": "{{timestamp_last_1h}}",
      "end_time": "{{timestamp}}"
    },
    "last_3h": {
      "start_time": "{{timestamp_last_3h}}",
      "end_time": "{{timestamp}}"
    },
    "last_6h": {
      "start_time": "{{timestamp_last_6h}}",
      "end_time": "{{timestamp}}"
    }
  },
  "filters": {
    "type_warning": {
      "type_filter": "Warning"
    },
    "type_normal": {
      "type_filter": "Normal"
    },
    "namespace_host": {
      "involved_object_namespace_filter": "{{projects.host.name}}"
    },
    "kind_pod": {
      "involved_object_kind_filter": "Pod"
    },
    "kind_node": {
      "involved_object_kind_filter": "Node"
    },
    "message_search": {
      "message_search": "Started"
    },
    "namespace_search": {
      "involved_object_namespace_search": "kube"
    }
  },
  "pagination": {
    "page_1": {
      "from": 0,
      "size": 5
    },
    "page_2": {
      "from": 5,
      "size": 5
    }
  },
  "histogram": {
    "interval_30m": {
      "interval": "30m"
    },
    "interval_1h": {
      "interval": "1h"
    }
  },
  "invalid_params": {
    "missing_time_range": {},
    "invalid_interval": {
      "operation": "histogram",
      "interval": "invalid"
    },
    "negative_from": {
      "operation": "query",
      "from": -1
    },
    "zero_size": {
      "operation": "query",
      "size": 0
    }
  }
}