    "metadata": {
      "name": "default-email-config",
      "annotations": {
        "kubesphere.io/creator": "admin"
      }
    },
    "spec": {
      "email": {
        "smartHost": {
          "port": 25,
          "host": "smtp.yunify.com"
        },
        "authUsername": "qiaoshilu",
        "from": "514060057@qq.com",
        "authPassword": {
          "valueFrom": {
            "secretKeyRef": {
              "key": "authPassword",
              "name": "global-email-config-secret"
            }
