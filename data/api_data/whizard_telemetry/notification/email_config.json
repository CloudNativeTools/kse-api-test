    "metadata": {
      "name": "global-email-config-secret",
      "annotations": {
        "kubesphere.io/creator": "admin"
      }
    },
    "type": "Opaque",
    "data": {
      "authPassword": "{{email_auth_password_base64}}"
    }
  },
  "update_email_secret": {
    "data": {
      "authPassword": "MlliMlY5REo5cHN0c2dKNQ=="
    }
  },
  "create_email_receiver": {
    "apiVersion": "notification.kubesphere.io/v2beta2",
    "kind": "Receiver",
    "metadata": {
      "name": "email-test",
      "annotations": {
        "kubesphere.io/creator": "admin"
      }
    },
    "spec": {
      "email": {
        "enabled": true,
        "to": ["514060057@qq.com"]
      }
    }
  },
  "verify_email_body": {
    "config": {
      "apiVersion": "notification.kubesphere.io/v2beta2",
      "kind": "Config",
      "metadata": {
        "name": "test-user-config",
        "labels": {
          "app": "notification-manager",
          "type": "default"
        }
      },
      "spec": {
        "email": {
          "from": "qiaoshilu@yunify.com",
          "smartHost": {
            "host": "smtp.yunify.com",
