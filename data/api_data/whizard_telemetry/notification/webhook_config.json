{
  "create_webhook_secret": {
    "apiVersion": "v1",
    "kind": "Secret",
    "metadata": {
      "name": "global-webhook-config-secret",
      "annotations": {
        "kubesphere.io/creator": "admin"
      }
    },
    "type": "Opaque",
    "data": {}
  },
  "create_webhook_receiver": {
    "apiVersion": "notification.kubesphere.io/v2beta2",
    "kind": "Receiver",
    "metadata": {
      "name": "global-webhook-receiver",
      "annotations": {
        "kubesphere.io/verify-type": "no",
        "kubesphere.io/creator": "admin"
      }
    },
    "spec": {
      "webhook": {
        "enabled": true,
        "url": "http://webhook-service.default/no-auth"
      }
    }
  },
  "verify_webhook_body": {
    "receiver": {
      "apiVersion": "notification.kubesphere.io/v2beta2",
      "kind": "Receiver",
      "metadata": {
        "name": "test-user-receiver",
        "labels": {
          "app": "notification-manager",
          "type": "global"
        }
      },
      "spec": {
        "webhook": {
          "enabled": false,
          "url": "http://webhook-service.default/no-auth"
        }
      }
    }
  },
  "create_webhook_configmap": {
    "apiVersion": "v1",
    "kind": "ConfigMap",
    "metadata": {
      "namespace": "default",
      "name": "nginx-config",
      "labels": {},
      "annotations": {
        "kubesphere.io/creator": "admin"
      }
    },
    "data": {
      "nginx.conf": "server {\n        listen 80;\n        location / {\n            proxy_pass http://localhost:8080;\n            proxy_set_header Host $host;\n        }\n    }\n    server {\n        listen 443 ssl;\n        ssl_certificate /etc/nginx/certs/tls.crt;\n        ssl_certificate_key /etc/nginx/certs/tls.key;\n         \n        location / {\n            proxy_pass http://localhost:8080;\n            proxy_set_header Host $host;\n        }\n    }"
    }
  },
  "create_webhook_service": {
    "apiVersion": "v1",
    "kind": "Service",
    "metadata": {
      "namespace": "default",
      "labels": {
        "app": "webhook-service"
      },
      "name": "webhook-service",
      "annotations": {
        "kubesphere.io/creator": "admin"
      }
    },
    "spec": {
      "sessionAffinity": "None",
      "selector": {
        "app": "webhook-service"
      },
      "ports": [
        {
          "name": "http-80",
          "protocol": "TCP",
          "targetPort": 80,
          "port": 80
        }
      ]
    }
  },
  "create_webhook_deployment": {
    "apiVersion": "apps/v1",
    "kind": "Deployment",
    "metadata": {
      "namespace": "default",
      "labels": {
        "app": "webhook-service"
      },
      "name": "webhook-service",
      "annotations": {
        "kubesphere.io/creator": "admin"
      }
    },
    "spec": {
      "replicas": 1,
      "selector": {
        "matchLabels": {
          "app": "webhook-service"
        }
      },
      "template": {
        "metadata": {
          "labels": {
            "app": "webhook-service"
          },
          "annotations": {
            "kubesphere.io/imagepullsecrets": "{}",
            "logging.kubesphere.io/logsidecar-config": "{}",
            "kubesphere.io/creator": "admin"
          }
        },
        "spec": {
          "containers": [
            {
              "name": "container-isvlz9",
              "imagePullPolicy": "IfNotPresent",
              "ports": [
                {
                  "name": "http-0",
                  "protocol": "TCP",
                  "containerPort": 8080
                }
              ],
              "image": "qiaoshilu/webhook-service:v3"
            },
            {
              "name": "container-lubymj",
              "imagePullPolicy": "IfNotPresent",
              "ports": [
                {
                  "name": "http-0",
                  "protocol": "TCP",
                  "containerPort": 80
                }
              ],
              "image": "nginx:1.21",
              "volumeMounts": [
                {
                  "name": "volume-9jkj9b",
                  "readOnly": true,
                  "mountPath": "/etc/nginx/conf.d/default.conf",
                  "subPath": "nginx.conf"
                },
                {
                  "name": "volume-g80w6m",
                  "readOnly": true,
                  "mountPath": "/etc/nginx/certs"
                }
              ]
            }
          ],
          "serviceAccount": "default",
          "terminationGracePeriodSeconds": 30,
          "initContainers": [],
          "volumes": [
            {
              "name": "volume-9jkj9b",
              "configMap": {
                "name": "nginx-config"
              }
            },
            {
              "name": "volume-g80w6m",
              "secret": {
                "secretName": "webhook-tls"
              }
            }
          ],
          "imagePullSecrets": []
        }
      },
      "strategy": {
        "type": "RollingUpdate",
        "rollingUpdate": {
          "maxUnavailable": "25%",
          "maxSurge": "25%"
        }
      }
    }
  },
  "create_webhook_tls_secret": {
    "apiVersion": "v1",
    "kind": "Secret",
    "metadata": {
      "namespace": "default",
      "name": "webhook-tls",
      "annotations": {
        "kubesphere.io/creator": "admin"
      }
    },
    "type": "kubernetes.io/tls",
    "data": {
      "tls.crt": "",
      "tls.key": ""
    }
  }
}